# =============================================================
# MediaFlow — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ── Database ─────────────────────────────────────────────────
PGDATABASE=mediaflow
PGUSER=mediaflow
PGPASSWORD=change_this_strong_password
PGHOST=db
PGPORT=5432
DATABASE_URL=postgres://mediaflow:change_this_strong_password@db:5432/mediaflow

# ── Security ─────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# =============================================================
# AI Provider API Keys (stored in DB via Admin → System tab)
# You can also set them here for initial seeding
# =============================================================

# OpenRouter (main AI provider for article writing)
# OPENROUTER_API_KEY_1=sk-or-...
# OPENROUTER_API_KEY_2=sk-or-...

# OpenAI (image generation + fallback writing)
# OPENAI_API_KEY=sk-...

# Google Gemini (competitor image analysis)
# GEMINI_API_KEY=AIza...

# Perplexity (keyword research)
# PERPLEXITY_API_KEY=pplx-...

# Tavily (external link finder)
# TAVILY_API_KEY=tvly-...

# kie.ai (FLUX image generation)
# KIEAI_API_KEY=...

# ── WordPress Global Fallback ─────────────────────────────────
# WP_URL=https://yourdomain.com
# WP_USERNAME=your_wp_username
# WP_PASSWORD=your_application_password

# ── Telegram Bot ─────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token
